+    # 当union为0时（所有点都是同一类别），jaccard应该为0
+    union_safe = union.clamp(min=eps)
+    jaccard = 1.0 - intersection / union_safe
+    
+    # 🔧 处理特殊情况：当union接近0时，强制jaccard为0
+    mask_zero_union = union < eps
+    jaccard[mask_zero_union] = 0.0
