+    添加数值稳定性保护，避免除零错误和NaN
     """
     p = len(gt_sorted)
+    if p == 0:
+        return torch.tensor(0.0, device=gt_sorted.device, dtype=gt_sorted.dtype)
+    
     gts = gt_sorted.sum()
     intersection = gts - gt_sorted.float().cumsum(0)
